---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import config from '../../../site.config';
import { formatDate, getProgrammes, getTestimonials, paths } from '../../lib/site';

/**
 * Outcomes — a flagged section (PRD §11), and a consent-gated one (PRD §21):
 * `getTestimonials` only ever returns quotes where consentGiven is true.
 */
export async function getStaticPaths() {
  if (!config.features.testimonials) return [];
  return [{ params: { slug: undefined } }];
}

const testimonials = await getTestimonials();
const programmes = await getProgrammes();
const byId = new Map(programmes.map((p) => [p.id, p]));

// Filtering is CSS-driven off a radio group, so it works without JavaScript.
const usedProgrammes = programmes.filter((p) => testimonials.some((t) => t.data.programme.id === p.id));
---

<Base
  pageTitle="Outcomes"
  description={`What people who attended ${config.brand.name} events in Oxford said afterwards — named, dated and attributed.`}
  path={paths.testimonials()}
  breadcrumbs={[{ name: 'Outcomes', path: paths.testimonials() }]}
>
  <Hero
    eyebrow={config.brand.name}
    title="What came out of the room"
    subline="Named, dated and attributed. Specific beats polished."
  />

  <section class="band band--cream" aria-labelledby="quotes">
    <div class="wrap">
      <h2 id="quotes" class="visually-hidden">Testimonials</h2>

      {
        testimonials.length > 0 ? (
          <>
            {usedProgrammes.length > 1 && (
              <div class="filter" role="group" aria-label="Filter by programme">
                <input class="visually-hidden filter__input" type="radio" name="prog" id="prog-all" value="all" checked />
                <label class="filter__chip" for="prog-all">
                  All
                </label>
                {usedProgrammes.map((programme) => (
                  <>
                    <input class="visually-hidden filter__input" type="radio" name="prog" id={`prog-${programme.data.slug}`} value={programme.data.slug} />
                    <label class="filter__chip" for={`prog-${programme.data.slug}`}>
                      {programme.data.name}
                    </label>
                  </>
                ))}
              </div>
            )}

            <div class="grid grid--2 quotes">
              {testimonials.map((t, i) => (
                <blockquote class="card quote" data-programme={byId.get(t.data.programme.id)?.data.slug} data-reveal data-reveal-delay={Math.min(i, 6) * 70}>
                  <p>“{t.data.quote}”</p>
                  <footer>
                    <cite>
                      {t.data.name} — {t.data.role}
                      {t.data.company && `, ${t.data.company}`}
                    </cite>
                    <span class="quote__when">
                      {[t.data.cohort, formatDate(t.data.date, { weekday: undefined })].filter(Boolean).join(' · ')}
                    </span>
                  </footer>
                </blockquote>
              ))}
            </div>
          </>
        ) : (
          <div class="empty">
            <p>
              Quotes from the most recent cohort are being collected. Nothing appears here until the person who said it
              has confirmed we can use their name.
            </p>
            <p class="empty__cta">
              <a href={paths.events()}>See the events →</a>
            </p>
          </div>
        )
      }
    </div>
  </section>
</Base>

<script>
  // Progressive enhancement only: without JS every quote stays visible.
  const inputs = document.querySelectorAll<HTMLInputElement>('.filter__input');
  const quotes = document.querySelectorAll<HTMLElement>('.quotes .quote');

  inputs.forEach((input) =>
    input.addEventListener('change', () => {
      quotes.forEach((quote) => {
        quote.hidden = input.value !== 'all' && quote.dataset.programme !== input.value;
      });
    }),
  );
</script>

<style>
  .filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-block-end: 2.25rem;
  }

  .filter__chip {
    display: inline-block;
    padding: 0.55rem 1rem;
    border: 1px solid rgba(5, 24, 23, 0.25);
    border-radius: var(--radius);
    font-family: var(--font-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--step-xs);
    cursor: pointer;
    transition: background-color 200ms var(--ease), border-color 200ms var(--ease), color 200ms var(--ease);
  }

  .filter__input:checked + .filter__chip {
    background: var(--ink-dark);
    border-color: var(--ink-dark);
    color: var(--cream);
  }

  .filter__input:focus-visible + .filter__chip {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
  }

  .quote p {
    font-family: var(--font-title);
    font-size: var(--step-lg);
    line-height: 1.4;
  }

  .quote footer {
    margin-block-start: 1.2rem;
  }

  .quote cite {
    display: block;
    font-family: var(--font-label);
    font-style: normal;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--step-xs);
  }

  .quote__when {
    display: block;
    margin-block-start: 0.3rem;
    font-size: var(--step-xs);
    color: var(--muted-on-cream);
  }

  .empty {
    max-width: var(--measure);
    font-size: var(--step-lg);
    line-height: 1.5;
  }

  .empty__cta {
    margin-block-start: 1.5rem;
    font-family: var(--font-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--step-xs);
  }
</style>
