---
/**
 * The wordmark, set live in the brand faces rather than shipped as a raster
 * logo — so a brand rename in site.config redraws it (PRD §4, §10).
 * `size="lockup"` is the two-line header lockup; `size="mark"` is the compact form.
 */
import config from '../../site.config';

interface Props {
  variant?: 'lockup' | 'mark';
  class?: string;
}

const { variant = 'lockup', class: className = '' } = Astro.props;
---

<span class:list={['wordmark', `wordmark--${variant}`, className]} aria-label={config.brand.name}>
  {/* "The Quad" mark from the design guidelines. Outer square follows the text
      colour (cream on dark, ink on cream — both permitted); centre is always
      amber. Never recoloured, rotated or skewed, per the guidelines. */}
  <svg class="wordmark__mark" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
    <rect x="8" y="8" width="84" height="84" fill="none" stroke="currentColor" stroke-width="16" />
    <rect x="36.5" y="36.5" width="27" height="27" fill="var(--gold)" />
  </svg>
  <span class="wordmark__text">{config.brand.name}</span>
</span>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    line-height: 1;
  }

  .wordmark__mark {
    width: 1.55rem;
    height: 1.55rem;
    flex: none;
    /* The centre square is the mark's clearspace anchor — keep it crisp. */
    shape-rendering: crispEdges;
  }

  .wordmark__text {
    font-family: var(--font-title);
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .wordmark--mark .wordmark__text {
    font-size: 1.05rem;
  }

  .wordmark--mark .wordmark__mark {
    width: 1.35rem;
    height: 1.35rem;
  }
</style>
