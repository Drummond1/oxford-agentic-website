---
import config from '../../site.config';
import { absoluteUrl } from '../lib/site';
import { graph, organizationSchema, websiteSchema } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  /** Site-relative path, used for the canonical URL. */
  path: string;
  ogImage?: string;
  /** Extra JSON-LD nodes for this page, merged into the sitewide @graph. */
  schemaNodes?: Array<Record<string, unknown> | null>;
  noindex?: boolean;
}

const { title, description, path, ogImage, schemaNodes = [], noindex = false } = Astro.props;

const canonical = absoluteUrl(path);
const ogUrl = ogImage ? absoluteUrl(ogImage) : absoluteUrl('/og/index.png');

// Organization and WebSite appear on every page — one entity, referenced by @id
// from every other node. Entity consistency is the core AI-citation signal (PRD §13).
const jsonLd = graph([organizationSchema(), websiteSchema(), ...schemaNodes]);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, follow" />}

<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#051817" />

{/* Preload the three faces that paint above the fold — the hero heading
    (Newsreader), body copy (IBM Plex Sans) and eyebrows (IBM Plex Mono) —
    so first paint is in-brand rather than a swapped fallback. */}
<link rel="preload" href="/fonts/newsreader-400.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/plex-sans-400.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/plex-mono-600.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={config.brand.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_GB" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogUrl} />

<script type="application/ld+json" is:inline set:html={jsonLd} />

{
  /* Analytics is provider-agnostic (PRD §14, §21) — swapping providers is a
     config change. Nothing loads while provider is 'none'. */
}
{
  config.analytics.provider === 'plausible' && (
    <script
      is:inline
      defer
      data-domain={config.analytics.siteId}
      src={config.analytics.scriptSrc ?? 'https://plausible.io/js/script.tagged-events.js'}
    />
  )
}
{
  config.analytics.provider === 'ga4' && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${config.analytics.siteId}`} />
      <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${config.analytics.siteId}');`} />
    </>
  )
}
