---
/**
 * FAQ accordion. Built on <details>/<summary> so it is keyboard-accessible,
 * open-by-default-when-printed, and fully readable with JavaScript off — which
 * also means crawlers and AI engines get the answers in the HTML (PRD §13).
 */
interface Props {
  faqs: Array<{ q: string; a: string }>;
}

const { faqs } = Astro.props;
---

<div class="faq">
  {
    faqs.map((faq, index) => (
      <details class="faq__item" name="faq" open={index === 0}>
        <summary class="faq__q">
          <span>{faq.q}</span>
          <span class="faq__icon" aria-hidden="true" />
        </summary>
        <div class="faq__a">
          <p>{faq.a}</p>
        </div>
      </details>
    ))
  }
</div>

<style>
  .faq {
    max-width: 48rem;
  }

  .faq__item {
    border-block-end: 1px solid var(--gold-hairline);
  }

  :global(.band--cream) .faq__item {
    border-block-end-color: rgba(5, 24, 23, 0.14);
  }

  .faq__q {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.15rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-title);
    font-size: var(--step-lg);
    line-height: 1.3;
    transition: color 200ms var(--ease);
  }

  .faq__q::-webkit-details-marker {
    display: none;
  }

  .faq__q:hover {
    color: var(--gold);
  }

  :global(.band--cream) .faq__q:hover {
    color: var(--burnt);
  }

  .faq__icon {
    flex: none;
    position: relative;
    width: 0.85rem;
    height: 0.85rem;
    margin-block-start: 0.45rem;
  }

  .faq__icon::before,
  .faq__icon::after {
    content: '';
    position: absolute;
    background: var(--gold);
    transition: transform 220ms var(--ease), opacity 220ms var(--ease);
  }

  :global(.band--cream) .faq__icon::before,
  :global(.band--cream) .faq__icon::after {
    background: var(--teal);
  }

  .faq__icon::before {
    inset-block-start: 50%;
    inset-inline: 0;
    height: 2px;
    transform: translateY(-50%);
  }

  .faq__icon::after {
    inset-inline-start: 50%;
    inset-block: 0;
    width: 2px;
    transform: translateX(-50%);
  }

  .faq__item[open] .faq__icon::after {
    opacity: 0;
    transform: translateX(-50%) rotate(90deg);
  }

  .faq__a {
    padding-block-end: 1.4rem;
    max-width: var(--measure);
  }

  .faq__a p {
    font-size: var(--step-sm);
    line-height: 1.65;
  }

  :global(.band--dark) .faq__a p {
    color: var(--muted-on-dark);
  }

  :global(.band--cream) .faq__a p {
    color: var(--muted-on-cream);
  }
</style>
