---
/**
 * The full-gold divider band with a giant Georgia numeral — the "01 / 02 / 03"
 * pattern from the deck (PRD §10). Sits outside the dark/cream alternation.
 */
interface Props {
  numeral: string;
  label: string;
  title?: string;
}

const { numeral, label, title } = Astro.props;
---

<section class="band band--gold divider">
  <div class="wrap divider__inner">
    <span class="divider__numeral" aria-hidden="true">{numeral}</span>
    <div class="divider__text">
      <span class="eyebrow">{label}</span>
      {title && <p class="divider__title">{title}</p>}
    </div>
  </div>
</section>

<style>
  .divider {
    padding-block: clamp(2rem, 1.2rem + 3vw, 3.25rem);
  }

  .divider__inner {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 0.5rem + 3vw, 2.75rem);
  }

  .divider__numeral {
    font-family: var(--font-title);
    font-size: clamp(3.5rem, 2rem + 9vw, 8rem);
    line-height: 0.82;
    color: var(--ink-dark);
    opacity: 0.9;
    flex: none;
  }

  .divider__text .eyebrow {
    margin-block-end: 0.4rem;
  }

  .divider__title {
    font-family: var(--font-title);
    font-size: var(--step-xl);
    line-height: 1.15;
    color: var(--ink-dark);
    max-width: 24ch;
  }
</style>
