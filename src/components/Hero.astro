---
/**
 * Full-bleed dark hero. The drifting gold grid is pure CSS — no JS at all,
 * which beats the PRD's ≤50KB budget outright and keeps LCP clean. It is
 * decorative, so it is hidden from assistive tech and stops under
 * prefers-reduced-motion.
 */
interface Props {
  eyebrow: string;
  title: string;
  subline?: string;
  /** Renders the drifting grid. Off for interior pages that want stillness. */
  motif?: boolean;
  size?: 'full' | 'compact';
}

const { eyebrow, title, subline, motif = false, size = 'compact' } = Astro.props;
---

<section class:list={['band band--dark hero', `hero--${size}`]}>
  {motif && <div class="hero__motif" aria-hidden="true" />}
  <div class="wrap hero__inner">
    <span class="eyebrow">{eyebrow}</span>
    <hr class="dash" />
    <h1 class="hero__title">{title}</h1>
    {subline && <p class="hero__subline">{subline}</p>}
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .hero--full {
    padding-block: clamp(4.5rem, 3rem + 10vw, 9rem);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero__title {
    max-width: 18ch;
  }

  .hero--compact .hero__title {
    font-size: var(--step-2xl);
    max-width: 24ch;
  }

  .hero__subline {
    margin-block-start: 1.6rem;
    max-width: 46ch;
    font-size: var(--step-lg);
    line-height: 1.45;
    color: var(--muted-on-dark);
  }

  /* Two offset gold grids drifting at different speeds, faded out at the
     edges so the band still reads as flat dark green. */
  .hero__motif {
    position: absolute;
    inset: -20%;
    z-index: 0;
    background-image:
      linear-gradient(to right, rgba(241, 175, 57, 0.16) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(241, 175, 57, 0.16) 1px, transparent 1px),
      radial-gradient(circle, rgba(241, 175, 57, 0.5) 1px, transparent 1.6px);
    background-size: 82px 82px, 82px 82px, 246px 246px;
    mask-image: radial-gradient(ellipse 75% 65% at 72% 38%, #000 0%, transparent 72%);
    animation: drift 68s linear infinite;
    will-change: background-position;
  }

  @keyframes drift {
    from {
      background-position: 0 0, 0 0, 0 0;
    }
    to {
      background-position: 246px 164px, 246px 164px, -246px 246px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__motif {
      animation: none;
    }
  }
</style>
